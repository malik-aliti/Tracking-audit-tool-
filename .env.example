# ── Anthropic (OBLIGATOIRE) ───────────────────────────────────────────────────
# Récupérer sur https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI

# ── URL de base (OBLIGATOIRE) ─────────────────────────────────────────────────
# En dev local : http://localhost:3000
# En prod Vercel : https://votre-app.vercel.app  (à changer après déploiement)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Chrome — chemin vers votre Chrome local (dev uniquement) ──────────────────
# macOS :
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows :
# CHROME_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
# Linux :
# CHROME_PATH=/usr/bin/google-chrome
CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# ── Google OAuth (optionnel — pour enrichir avec données GA4 + Google Ads) ────
# Créer sur https://console.cloud.google.com/
# APIs à activer : Google Analytics Data API, Google Analytics Admin API
# Redirect URI à ajouter : http://localhost:3000/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# ── Meta OAuth (optionnel — pour enrichir avec données Pixel + CAPI) ──────────
# Créer sur https://developers.facebook.com/
# Redirect URI à ajouter : http://localhost:3000/api/meta/callback
META_APP_ID=
META_APP_SECRET=
