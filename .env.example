# ─── Anthropic (OBLIGATOIRE) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── URL de base (OBLIGATOIRE) ────────────────────────────────────────────────
# En dev : http://localhost:3000
# En prod : https://votre-domaine.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Google OAuth (GA4 + Google Ads) ─────────────────────────────────────────
# Créer sur https://console.cloud.google.com/
# APIs : Google Analytics Data API, Google Analytics Admin API, Google Ads API
# Redirect URI : ${NEXT_PUBLIC_BASE_URL}/api/google/callback
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_ADS_DEVELOPER_TOKEN=xxxxx

# ─── Meta OAuth (Pixel + CAPI) ────────────────────────────────────────────────
# Créer sur https://developers.facebook.com/
# Redirect URI : ${NEXT_PUBLIC_BASE_URL}/api/meta/callback
META_APP_ID=xxxxx
META_APP_SECRET=xxxxx

# ─── Chrome (dev local uniquement) ───────────────────────────────────────────
# macOS : /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux : /usr/bin/google-chrome ou /usr/bin/chromium-browser
# Windows : C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
CHROME_PATH=/usr/bin/google-chrome
